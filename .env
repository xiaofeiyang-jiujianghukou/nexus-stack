# ========================
# Maven 本地仓库 & Settings
# ========================
MAVEN_REPO_HOST=/data/maven/repo
MAVEN_SETTINGS_HOST=/opt/APP/maven/apache-maven-3.9.11/conf/settings.xml

# 容器内路径（固定，不要改）
MAVEN_REPO_CONTAINER=/root/.m2
MAVEN_SETTINGS_CONTAINER=/tmp/settings.xml

# ========================
# MySQL - Container（容器内部通信）
# ========================
MYSQL_ROOT_PASSWORD=123456
MYSQL_HOST=mysql
MYSQL_PORT_INTERNAL=3306
MYSQL_DATABASE=nexus_stack
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456

# ========================
# MySQL - Host（宿主机访问）
# ========================
MYSQL_PORT_EXTERNAL=33306


# ========================
# Redis - Container（容器内部通信）
# ========================
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379

# ========================
# Redis - Host（宿主机访问）
# ========================
REDIS_PORT_EXTERNAL=26379


# ========================
# Services - Host Ports（对外服务端口）
# ========================
AGENT_PORT_EXTERNAL=28080
ORDER_PORT_EXTERNAL=28081
PRODUCT_PORT_EXTERNAL=28082

# ========================
# Spring Profile
# ========================
#SPRING_PROFILES_ACTIVE=docker
SPRING_PROFILES_ACTIVE=pro