version: '3.8'

services:

  zookeeper:
    image: crpi-27zlqugq2208c0pz.cn-hangzhou.personal.cr.aliyuncs.com/xiaofeiyang930112/cp-zookeeper:7.5.0
    container_name: nexus-stack-zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181

  kafka:
    image: crpi-27zlqugq2208c0pz.cn-hangzhou.personal.cr.aliyuncs.com/xiaofeiyang930112/cp-kafka:7.5.0
    container_name: nexus-stack-kafka
    depends_on:
      - zookeeper
    ports:
      - "9092:9092"   # 供容器内部/集群内使用 (INTERNAL)
      - "29092:29092" # 供宿主机/IDEA 使用 (EXTERNAL)
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      #KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://localhost:9092
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      #KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092
      #KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      #KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      # 1. 定义两个监听器：一个叫 INTERNAL, 一个叫 EXTERNAL
      KAFKA_LISTENERS: INTERNAL://0.0.0.0:9092,EXTERNAL://0.0.0.0:29092
      # 2. 明确告诉客户端该找谁：内部找 kafka:9092, 外部找 localhost:29092
      KAFKA_ADVERTISED_LISTENERS: INTERNAL://kafka:9092,EXTERNAL://localhost:29092
      # 3. 建立映射：两个都用明文传输（PLAINTEXT）
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT
      # 4. 重点：Kafka 节点之间自己说话用 INTERNAL 协议
      KAFKA_INTER_BROKER_LISTENER_NAME: INTERNAL

  clickhouse:
    image: crpi-27zlqugq2208c0pz.cn-hangzhou.personal.cr.aliyuncs.com/xiaofeiyang930112/clickhouse-server:23
    container_name: nexus-stack-clickhouse
    ports:
      - "28123:8123"
      - "29000:9000"

  flink-jobmanager:
    image: crpi-27zlqugq2208c0pz.cn-hangzhou.personal.cr.aliyuncs.com/xiaofeiyang930112/flink:1.18
    container_name: nexus-stack-jobmanager
    command: jobmanager
    ports:
      - "28081:8081"

  flink-taskmanager:
    image: crpi-27zlqugq2208c0pz.cn-hangzhou.personal.cr.aliyuncs.com/xiaofeiyang930112/flink:1.18
    container_name: nexus-stack-taskmanager
    depends_on:
      - flink-jobmanager
    command: taskmanager
    environment:
      - JOB_MANAGER_RPC_ADDRESS=flink-jobmanager
